# ---------- Core ----------
APP_ENV=dev
APP_NAME=ai-content-studio
LOG_LEVEL=info
SECRET_KEY=change-me-32-bytes-min

# ---------- Database ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=studio
POSTGRES_USER=studio
POSTGRES_PASSWORD=studio
DATABASE_URL=postgresql+asyncpg://studio:studio@postgres:5432/studio

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- Qdrant ----------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---------- Storage ----------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=studio-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE=http://localhost:9000/studio-media

# ---------- Auth (Clerk) ----------
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=
CLERK_JWKS_URL=

# ---------- Payments ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ---------- LLM Providers ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
VOYAGE_API_KEY=
ELEVENLABS_API_KEY=
REPLICATE_API_TOKEN=

# ---------- Social / Publishing ----------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
WORDPRESS_DEFAULT_AUTH=app_password

# ---------- Research / Scraping ----------
SERPAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-content-studio/1.0

# ---------- Observability ----------
SENTRY_DSN=
POSTHOG_API_KEY=
